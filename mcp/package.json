{
  "name": "sampler-mcp",
  "version": "0.1.6",
  "description": "MCP server for Sampler iOS visual feedback annotations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sampler-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsx src/index.ts",
    "server": "tsx src/index.ts server",
    "doctor": "tsx src/index.ts doctor",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "sampler",
    "ios",
    "annotations"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
